// 创建axios实例
const service = axios.create({
  baseURL: process.env.NODE_ENV === 'production' ? '' : '', // 生产环境和开发环境都使用相对路径
  timeout: 15000, // 请求超时时间
  withCredentials: false, // 避免跨域问题
  headers: {
    'Content-Type': 'application/json',
    'X-Requested-With': 'XMLHttpRequest',
    'Accept': 'application/json'
  }
})

// 确保全局axios也使用相同的拦截器配置（兼容性处理）
if (typeof window !== 'undefined' && window.axios) {
  // 清除现有拦截器
  window.axios.interceptors.request.clear();
  window.axios.interceptors.response.clear();
}

// 生产环境关闭调试信息

// 请求拦截器
service.interceptors.request.use(
  config => {
    // 处理baseURL，确保能同时支持Laravel API和原生PHP API
    if (!config.url) {
      return config;
    }

    // 记录原始URL
    const originalUrl = config.url;

    // 如果URL已经是完整的绝对路径（以/Tapp/开头），直接使用
    if (config.url.startsWith('/Tapp/')) {
      config.baseURL = '';
      console.log('URL处理[Tapp路径]:', originalUrl, '->', config.baseURL + config.url);
    }
    // 处理Laravel API风格的路径（以/api/开头）
    else if (config.url.startsWith('/api/')) {
      config.baseURL = '';
      console.log('URL处理[API路径]:', originalUrl, '->', config.baseURL + config.url);
    }
    // 处理App V1 API路径（以/app/开头）
    else if (config.url.startsWith('/app/')) {
      config.url = '/api' + config.url;
      config.baseURL = '';
      console.log('URL处理[App API路径]:', originalUrl, '->', config.baseURL + config.url);
    }
    // 处理相对路径的PHP文件
    else if (config.url.endsWith('.php') && !config.url.startsWith('/')) {
      // 相对路径的PHP文件，添加/Tapp/admin/api前缀
      config.url = '/Tapp/admin/api/' + config.url;
      config.baseURL = '';
      console.log('URL处理[PHP文件]:', originalUrl, '->', config.baseURL + config.url);
    }
    // 处理以/admin/api开头的路径
    else if (config.url.startsWith('/admin/api/')) {
      // 添加/Tapp前缀
      config.url = '/Tapp' + config.url;
      config.baseURL = '';
      console.log('URL处理[admin/api路径]:', originalUrl, '->', config.baseURL + config.url);
    }
    // 邀请取水API使用Laravel路由
    else if (config.url.startsWith('/invite-water/')) {
      config.url = '/api' + config.url;
      config.baseURL = '';
      console.log('URL处理[邀请取水API]:', originalUrl, '->', config.baseURL + config.url);
    }
    // 其他情况，使用默认的/Tapp/admin/api前缀
    else {
      if (!config.baseURL) {
        config.baseURL = '/Tapp/admin/api';
      }
      console.log('URL处理[默认路径]:', originalUrl, '->', config.baseURL + config.url);
    }

    // 设置防缓存参数
    const now = Date.now();
    if (config.method === 'get') {
      config.params = { ...config.params, _t: now }
    } else {
      config.data = { ...config.data, _t: now }
    }

    // 添加更多Headers防止重定向循环
    config.headers['X-No-Redirect'] = 'true';
    config.headers['X-Requested-With'] = 'XMLHttpRequest';
    config.headers['X-Ajax-Request'] = 'true';

    // 防止跨域请求时发送cookie
    config.withCredentials = false;

    // 如果不需要跳过token验证，则添加token
    if (!config.skipAuthToken) {
      // 动态导入auth工具以避免循环依赖
      let token;
      try {
        // 检查是否处于模拟登录模式
        const simulateMode = sessionStorage.getItem('simulate_mode');
        const simulateToken = sessionStorage.getItem('simulate_token');
        
        if (simulateMode === 'true' && simulateToken) {
          // 模拟登录模式，使用模拟登录token
          token = simulateToken;
          console.log('使用模拟登录token:', token.substring(0, 20) + '...');
        } else {
          // 正常模式，使用认证工具获取最新有效token
          // 优先从localStorage获取，确保一致性
          token = localStorage.getItem('token') || 
                  sessionStorage.getItem('token') || 
                  localStorage.getItem('branch_token');
          
          // 如果有token，进行基本验证（支持多种token格式）
          if (token) {
            try {
              // 检查token是否为有效字符串（支持Sanctum token格式：id|hash 和 JWT格式）
              if (typeof token !== 'string' || token.trim().length < 10) {
                console.warn('⚠️ 检测到无效token格式，清除并跳过请求');
                localStorage.removeItem('token');
                sessionStorage.removeItem('token');
                token = null;
              } else {
                // 支持多种token格式：
                // 1. Sanctum token: id|hash
                // 2. JWT token: header.payload.signature
                // 3. 其他自定义格式
                const isSanctumToken = token.includes('|');
                const isJWTToken = token.split('.').length === 3;
                const isValidFormat = isSanctumToken || isJWTToken || token.length > 20;
                
                if (!isValidFormat) {
                  console.warn('⚠️ 检测到不支持的token格式，清除并跳过请求');
                  localStorage.removeItem('token');
                  sessionStorage.removeItem('token');
                  token = null;
                } else {
                  console.log('✅ Token格式验证通过:', isSanctumToken ? 'Sanctum' : isJWTToken ? 'JWT' : 'Custom');
                }
              }
            } catch (e) {
              console.warn('⚠️ token验证失败，清除并跳过请求:', e.message);
              localStorage.removeItem('token');
              sessionStorage.removeItem('token');
              token = null;
            }
          }
        }
      } catch (error) {
        console.error('获取token时出错:', error);
        token = null;
      }
      
      // 安卓设备调试：验证token
      if (isAndroidDevice() && token) {
        validateToken().then(result => {
          if (!result.valid) {
            logDebugInfo('invalidTokenDetected', {
              reason: result.reason,
              url: config.url,
              method: config.method
            });
          }
        });
      }
      
      if (token) {
        config.headers['Authorization'] = `Bearer ${token}`;
      }
    }

    // 设置内容类型
    if (!config.headers['Content-Type'] && !config.headers['content-type']) {
      if (config.data instanceof FormData) {
        // FormData类型不设置Content-Type，浏览器会自动处理
        delete config.headers['Content-Type'];
      } else {
        config.headers['Content-Type'] = 'application/json';
      }
    }

    // 生产环境关闭日志

    // 支持请求重试配置
    config.retries = config.retries || 0 // 默认不重试
    config.retryCount = 0 // 已重试次数
    
    return config;
  },
  error => {
    // 请求错误
    console.error('Request Error:', error);
    return Promise.reject(error);
  }
)

// 统一处理Token过期的函数
const handleTokenExpired = async () => {
  if (isShowingLoginExpiredDialog) {
    return;
  }

  // 安卓设备调试：记录token过期事件
  if (isAndroidDevice()) {
    logDebugInfo('tokenExpired', {
      lastTokenErrorTime,
      currentTime: Date.now()
    });
  }

  isShowingLoginExpiredDialog = true;
  lastTokenErrorTime = Date.now();

  // 检查是否是分支机构用户 - 只有当前在分支机构页面才判定为分支机构用户
  const branchCode = localStorage.getItem('branch_code')
  const currentPath = window.location.hash
  // 修复：只有当前路径包含分支机构相关路径才判定为分支机构用户，避免localStorage残留导致误判
  const isBranchUser = currentPath.includes('/branch') || currentPath.includes('branch-login') || currentPath.includes('branch-wechat')

  // 分支机构用户直接跳转，不显示弹窗
  if (isBranchUser) {
    // 直接清除数据并跳转，不显示任何提示
    try {
      const { clearAuthData } = await import('@/utils/auth')
      clearAuthData()
    } catch (error) {
      console.error('清除认证数据失败:', error)
      // 兜底清除
      localStorage.removeItem('token')
      localStorage.removeItem('userInfo')
      localStorage.removeItem('branch_token')
      localStorage.removeItem('branch_userInfo')
    }

    // 静默跳转到分支机构登录页
    setTimeout(() => {
      const currentBranchCode = localStorage.getItem('branch_code') || 'YXY02'
      window.location.href = `/app/#/branch-login?branch_code=${currentBranchCode}`
      isShowingLoginExpiredDialog = false
    }, 500)
    return
  }

  Toast.confirm({
    title: '登录失效',
    message: '您的登录已过期或无效，请重新登录',
    confirmButtonText: '重新登录',
    showCancelButton: false,
    closeOnClickOverlay: false
  }).then(async () => {
    // 使用新的认证工具清除登录状态
    try {
      const { clearAuthData } = await import('@/utils/auth')
      clearAuthData()
    } catch (error) {
      console.error('清除认证数据失败:', error)
      // 兜底清除
      localStorage.removeItem('token')
      localStorage.removeItem('userInfo')
      localStorage.removeItem('branch_token')
      localStorage.removeItem('branch_userInfo')
    }

    // 重定向到对应的登录页
    setTimeout(() => {
      const host = window.location.host
      if (host.includes('pay.itapgo.com')) {
        if (isBranchUser) {
          // 分支机构用户跳转到分支机构登录页
          const branchCode = localStorage.getItem('branch_code') || 'XM0001'
          window.location.href = `/app/#/branch-login?branch_code=${branchCode}`
        } else {
          // 官方用户跳转到官方登录页
          window.location.href = '/app/#/login'
        }
      } else {
        window.location.href = '/login'
      }
      isShowingLoginExpiredDialog = false;
    }, 1000)
  }).catch(() => {
    isShowingLoginExpiredDialog = false;
  })
}

