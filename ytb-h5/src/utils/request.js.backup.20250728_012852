    // 获取完整的错误信息
    const errorMessage = getErrorMessage(error)

    // 检查是否是特定的401错误
    if (error.response && error.response.status === 401) {
      // 检查当前是否在分支机构相关页面
      const currentPath = window.location.hash || window.location.pathname
      const isBranchPage = currentPath.includes('/branch') || currentPath.includes('#/branch')
      const isBranchLoginPage = currentPath.includes('/branch-login') || currentPath.includes('#/branch/login')
      
      // 检查是否是分支机构相关API
      const isBranchApi = error.config && error.config.url && (
        error.config.url.includes('/api/branch/') ||
        error.config.url.includes('/branch/') ||
        error.config.url.includes('branch_')
      )
      
      // 如果在分支机构登录页面，静默处理401错误，不显示错误提示
      if (isBranchLoginPage) {
        console.log('分支机构登录页面检测到401错误，静默处理:', error.config?.url)
        return Promise.reject(error)
      }
      
      // 如果是分支机构相关页面或API，静默处理，不显示任何错误提示
      if (isBranchPage || isBranchApi) {
        console.log('分支机构相关页面/API检测到401错误，静默处理:', {
          url: error.config?.url,
          currentPath,
          isBranchPage,
          isBranchApi
        })
        
        // 检查是否在短时间内多次报错，避免重复跳转
        const now = Date.now()
        if (now - lastTokenErrorTime > MIN_ERROR_INTERVAL) {
          lastTokenErrorTime = now
          
          // 清除认证数据
          localStorage.removeItem('token')
          localStorage.removeItem('userInfo')
          localStorage.removeItem('branch_token')
          localStorage.removeItem('branch_userInfo')
          const branchCode = localStorage.getItem('branch_code') || 'YXY02'

          // 静默重定向到分支机构登录页，不显示任何提示
          setTimeout(() => {
            window.location.href = `/app/#/branch-login?branch_code=${branchCode}`
          }, 1000)
        }
        
        // 直接拒绝错误，不再执行后续的错误处理逻辑
        return Promise.reject(error)
      }
      
      // 检查是否是VIP分红相关API的401错误
      const isVipDividendApi = error.config && error.config.url && error.config.url.includes('vip_dividends.php');
      
      if (isVipDividendApi) {
        // VIP分红API的401错误完全静默处理，不记录任何日志
        return Promise.reject(error);
      }
      
      // 安卓设备调试：记录401错误
      if (isAndroidDevice()) {
        logDebugInfo('apiResponse401', {
          url: error.config?.url,
          method: error.config?.method,
          responseData: error.response?.data,
          lastTokenErrorTime,
          currentTime: Date.now(),
          timeSinceLastError: Date.now() - lastTokenErrorTime
        });
      }
      
      // 生产环境关闭日志
      
      // 其他401错误才显示Token过期提示
      // 检查是否在短时间内多次报错
      const now = Date.now()
      if (now - lastTokenErrorTime > MIN_ERROR_INTERVAL) {
        lastTokenErrorTime = now
        
        //         // 先尝试自动刷新令牌
        //         import('@/utils/auth').then(authModule => {
        //           return authModule.refreshTokenIfNeeded()
        //         }).then(refreshSuccess => {
        //           if (refreshSuccess) {
        //             console.log('✅ 令牌自动刷新成功，重试请求')
        //             // 令牌刷新成功，重试原请求
        //             service.request(error.config).then(response => {
        //               console.log('✅ 重试请求成功')
        //             }).catch(retryError => {
        //               console.error('❌ 重试请求失败:', retryError)
        //               handleTokenExpired()
            })
          } else {
            // 令牌刷新失败，显示登录过期提示
            handleTokenExpired()
          }
        }).catch(refreshError => {
          console.error('❌ 令牌自动刷新失败:', refreshError)
          // 刷新失败，显示登录过期提示
          handleTokenExpired()
        })
      }
      return Promise.reject(error)
    }

    // 服务器错误 (500系列)
    if (error.response && error.response.status >= 500) {
      // 检查是否需要静默处理错误
      if (!error.config.silentError) {
        showFailToast('服务器繁忙，请稍后再试')
      }
      return Promise.reject(error)
    }

    // 网络错误
    if (!error.response) {
      // 检查是否需要静默处理错误
      if (!error.config.silentError) {
        showFailToast('网络连接失败，请检查网络')
      }
      return Promise.reject(error)
    }

    // 超时错误
    if (error.message.includes('timeout')) {
      // 检查是否需要静默处理错误
      if (!error.config.silentError) {
        showFailToast('请求超时，请检查网络连接')
      }
      return Promise.reject(error)
    }

    // 其他错误显示错误消息
    if (!error.config.silentError) {
      showFailToast(errorMessage || '请求失败')
    }
    return Promise.reject(error)
  }
)

// 处理请求错误
const handleRequestError = async (error, config, requestKey) => {
  // 获取完整的错误信息
  const errorMessage = getErrorMessage(error)

  // 检查是否是"Network Error"
  const isNetworkError = errorMessage.includes('Network Error') || !error.response
  // 检查是否是超时
  const isTimeoutError = errorMessage.includes('timeout')
  // 检查服务器错误
  const isServerError = error.response && error.response.status >= 500
  // 是否是VIP相关接口
  const isVipRelatedApi = config.url && (
    config.url.includes('/vip_') ||
    config.url.includes('/api/vip/') ||
    config.url.includes('/vip/')
  )
  // 是否是VIP团队信息API (需要排除，允许其返回真实数据)
  const isVipTeamInfoApi = config.url && config.url.includes('vip_team_info.php') && !config.url.includes('/api/vip/team-stats')
  // 检查是否是404错误
  const is404Error = error.response && error.response.status === 404

  // 生产环境关闭日志

  // 重试逻辑 - 对于VIP相关接口特别处理
  if (config && (isNetworkError || isTimeoutError || isServerError || is404Error) &&
    (isVipRelatedApi || config.retry)) {

    // 设置自定义重试次数
    const retry = config.retry || MAX_RETRIES
    const retryDelay = config.retryDelay || RETRY_DELAY

    // 检查当前请求的重试次数
    if (!retryTimes[requestKey]) {
      retryTimes[requestKey] = {
        count: 0,
        timestamp: Date.now()
      }
    }

    // 如果重试次数未达上限，则进行重试
    if (retryTimes[requestKey].count < retry) {
      retryTimes[requestKey].count++
      retryTimes[requestKey].timestamp = Date.now()

      // 生产环境关闭日志

              // 对于404错误，尝试修正API路径
        if (is404Error) {
          // 检查是否是VIP相关接口
          if (isVipRelatedApi) {
            // 生产环境关闭日志

