  if (error.response && (
      error.response.status === 401 ||
      error.response.status === 403 ||
      (error.response.data && error.response.data.code === 1002)
    )) {
    // 生产环境关闭日志

    // 检查是否在短时间内多次报错
    const now = Date.now()
    if (now - lastTokenErrorTime > MIN_ERROR_INTERVAL) {
