<template>
  <div class="sms-statistics-page">
    <el-card class="box-card">
      <template #header>
        <div class="card-header">
          <span>短信统计分析</span>
          <div class="header-buttons">
            <el-button type="primary" @click="exportData">导出数据</el-button>
          </div>
        </div>
      </template>

      <!-- 筛选条件 -->
      <div class="filter-container">
        <el-form :inline="true" :model="filters" class="demo-form-inline">
          <el-form-item label="日期范围">
            <el-date-picker
              v-model="filters.dateRange"
              type="daterange"
              range-separator="至"
              start-placeholder="开始日期"
              end-placeholder="结束日期"
              value-format="YYYY-MM-DD"
              :shortcuts="dateRangeShortcuts"
              clearable
            />
          </el-form-item>
          <el-form-item label="统计类型">
            <el-select v-model="filters.type" placeholder="请选择统计类型">
              <el-option label="按日统计" value="daily" />
              <el-option label="按周统计" value="weekly" />
              <el-option label="按月统计" value="monthly" />
            </el-select>
          </el-form-item>
          <!-- 暂时移除工程师筛选 -->
          <!-- <el-form-item label="工程师">
            <el-select v-model="filters.engineer_id" placeholder="全部工程师" clearable>
              <el-option
                v-for="engineer in engineers"
                :key="engineer.id"
                :label="engineer.name"
                :value="engineer.id"
              />
            </el-select>
          </el-form-item> -->
          <el-form-item>
            <el-button type="primary" @click="handleSearch">查询</el-button>
            <el-button @click="resetFilters">重置</el-button>
          </el-form-item>
        </el-form>
      </div>

      <!-- 统计卡片 -->
      <div class="stat-cards">
        <el-row :gutter="20">
          <el-col :span="6">
            <el-card shadow="hover" class="stat-card">
              <div class="stat-card-content">
                <div class="stat-icon">
                  <el-icon><Document /></el-icon>
                </div>
                <div class="stat-info">
                  <div class="stat-title">总发送量</div>
                  <div class="stat-value">{{ overview.total }}</div>
                </div>
              </div>
            </el-card>
          </el-col>
          <el-col :span="6">
            <el-card shadow="hover" class="stat-card">
              <div class="stat-card-content">
                <div class="stat-icon">
                  <el-icon><CircleCheck /></el-icon>
                </div>
                <div class="stat-info">
                  <div class="stat-title">发送成功</div>
                  <div class="stat-value">{{ overview.success }}</div>
                </div>
              </div>
            </el-card>
          </el-col>
          <el-col :span="6">
            <el-card shadow="hover" class="stat-card">
              <div class="stat-card-content">
                <div class="stat-icon">
                  <el-icon><CircleClose /></el-icon>
                </div>
                <div class="stat-info">
                  <div class="stat-title">发送失败</div>
                  <div class="stat-value">{{ overview.failed }}</div>
                </div>
              </div>
            </el-card>
          </el-col>
          <el-col :span="6">
            <el-card shadow="hover" class="stat-card">
              <div class="stat-card-content">
                <div class="stat-icon">
                  <el-icon><DataAnalysis /></el-icon>
                </div>
                <div class="stat-info">
                  <div class="stat-title">成功率</div>
                  <div class="stat-value">{{ overview.successRate }}%</div>
                </div>
              </div>
            </el-card>
          </el-col>
        </el-row>
      </div>

      <!-- 图表区域 -->
      <div class="chart-container">
        <el-row :gutter="20">
          <el-col :span="12">
            <el-card shadow="hover" class="chart-card">
              <template #header>
                <div class="chart-header">
                  <span>短信类型分布</span>
                </div>
              </template>
              <div id="type-chart" class="chart"></div>
            </el-card>
          </el-col>
          <el-col :span="12">
            <el-card shadow="hover" class="chart-card">
              <template #header>
                <div class="chart-header">
                  <span>高频使用手机号</span>
                </div>
              </template>
              <div id="phone-chart" class="chart"></div>
            </el-card>
          </el-col>
        </el-row>
        <el-row :gutter="20" style="margin-top: 20px;">
          <el-col :span="24">
            <el-card shadow="hover" class="chart-card">
              <template #header>
                <div class="chart-header">
                  <span>发送量趋势</span>
                </div>
              </template>
              <div id="trend-chart" class="chart"></div>
            </el-card>
          </el-col>
        </el-row>
      </div>

      <!-- 数据表格 -->
      <el-card shadow="hover" style="margin-top: 20px;">
        <template #header>
          <div class="table-header">
            <span>发送成功率统计</span>
          </div>
        </template>
        <el-table
          :data="tableData"
          border
          style="width: 100%"
          v-loading="loading"
        >
          <el-table-column prop="date" label="日期" width="120" />
          <el-table-column prop="success" label="成功数" width="100" />
          <el-table-column prop="failed" label="失败数" width="100" />
          <el-table-column prop="successRate" label="成功率" width="100">
            <template #default="scope">
              {{ scope.row.successRate }}%
            </template>
          </el-table-column>
        </el-table>
      </el-card>
    </el-card>
  </div>
</template>

<script>
import { ref, reactive, onMounted, nextTick } from 'vue';
import { ElMessage } from 'element-plus';
import * as echarts from 'echarts/core';
import { TitleComponent, TooltipComponent, LegendComponent, GridComponent } from 'echarts/components';
import { PieChart, BarChart, LineChart } from 'echarts/charts';
import { CanvasRenderer } from 'echarts/renderers';
import smsApi from '../../../api/smsApi';
import { Document, CircleCheck, CircleClose, DataAnalysis } from '@element-plus/icons-vue';

// 注册必须的组件
echarts.use([
  TitleComponent,
  TooltipComponent,
  LegendComponent,
  GridComponent,
  PieChart,
  BarChart,
  LineChart,
  CanvasRenderer
]);

export default {
  name: 'SmsStatistics',
  components: {
    Document,
    CircleCheck,
    CircleClose,
    DataAnalysis
  },
  setup() {
    // 数据加载状态
    const loading = ref(false);

    // 工程师列表 - 暂时不用
    // const engineers = ref([]);

    // 图表实例
    const charts = {
      status: null,
      engineer: null,
      trend: null
    };

    // 日期范围快捷选项
    const dateRangeShortcuts = [
      {
        text: '最近一周',
        value: () => {
          const end = new Date();
          const start = new Date();
          start.setTime(start.getTime() - 3600 * 1000 * 24 * 7);
          return [start, end];
        },
      },
      {
        text: '最近一个月',
        value: () => {
          const end = new Date();
          const start = new Date();
          start.setTime(start.getTime() - 3600 * 1000 * 24 * 30);
          return [start, end];
        },
      },
      {
        text: '最近三个月',
        value: () => {
          const end = new Date();
          const start = new Date();
          start.setTime(start.getTime() - 3600 * 1000 * 24 * 90);
          return [start, end];
        },
      },
    ];

    // 筛选条件
    const filters = reactive({
      dateRange: getDefaultDateRange(),
      type: 'daily'
    });

    // 统计概览数据
    const overview = reactive({
      total: 0,
      success: 0,
      failed: 0,
      successRate: 0
    });

    // 表格数据
    const tableData = ref([]);

    // 获取默认日期范围（最近30天）
    function getDefaultDateRange() {
      const end = new Date();
      const start = new Date();
      start.setTime(start.getTime() - 3600 * 1000 * 24 * 30);
      return [
        formatDateString(start),
        formatDateString(end)
      ];
    }

    // 格式化日期为 YYYY-MM-DD
    function formatDateString(date) {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    }

    // 格式化货币
    function formatCurrency(value) {
      const num = parseFloat(value);
      if (isNaN(num)) return '0.00';
      return num.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }



    // 获取统计数据
    const fetchData = async () => {
      loading.value = true;
      try {
        const params = {
          type: filters.type
        };

        if (filters.dateRange && filters.dateRange.length === 2) {
          params.start_date = filters.dateRange[0];
          params.end_date = filters.dateRange[1];
        }

        // 使用API获取统计数据
        const response = await smsApi.getSmsStatistics(params);
        if (response.data.code === 0) {
          const data = response.data.data;

          // 更新概览数据
          overview.total = data.totalStats.total || 0;
          overview.success = data.totalStats.success || 0;
          overview.failed = data.totalStats.failed || 0;
          overview.successRate = data.totalStats.successRate || 0;

          // 更新表格数据
          if (data.successRate && Array.isArray(data.successRate)) {
            tableData.value = data.successRate || [];
          }

          // 更新图表数据
          const chartsData = {
            type_distribution: data.typeDistribution || [],
            frequent_phones: data.frequentPhones || [],
            trends: {
              dates: [],
              counts: []
            }
          };

          // 处理趋势数据
          if (data.dailySending && Array.isArray(data.dailySending)) {
            data.dailySending.forEach(item => {
              chartsData.trends.dates.push(item.date);
              chartsData.trends.counts.push(Number(item.count || 0));
            });
          }

          // 更新图表
          updateCharts(chartsData);
        } else {
          // API调用失败，显示错误信息
          console.error('获取统计数据失败:', response.data?.message || '未知错误');
          ElMessage.error('获取统计数据失败: ' + (response.data?.message || '未知错误'));
          clearData();
        }
      } catch (error) {
        console.error('获取统计数据失败:', error);
        ElMessage.error('获取统计数据失败: ' + (error.response?.data?.message || error.message));
        // 显示错误信息
        clearData();
      } finally {
        loading.value = false;
      }
    };

    // 清空数据方法
    const clearData = () => {
      // 清空概览数据
      overview.total = 0;
      overview.success = 0;
      overview.failed = 0;
      overview.successRate = 0;

      // 清空表格数据
      tableData.value = [];

      // 清空图表数据
      const emptyChartsData = {
        type_distribution: [],
        frequent_phones: [],
        trends: {
          dates: [],
          counts: []
        }
      };

      // 更新图表
      updateCharts(emptyChartsData);
    };

    // 更新图表
    const updateCharts = (data) => {
      nextTick(() => {
        // 短信类型分布图
        if (data.type_distribution && Array.isArray(data.type_distribution)) {
          // 确保所有值都是数字
          const safeDistribution = data.type_distribution.map(item => ({
            name: item.type,
            value: Number(item.count || 0)
          }));

          const typeChart = echarts.init(document.getElementById('type-chart'));
          typeChart.setOption({
            tooltip: {
              trigger: 'item',
              formatter: '{a} <br/>{b}: {c} ({d}%)'
            },
            legend: {
              orient: 'vertical',
              left: 10,
              data: safeDistribution.map(item => item.name)
            },
            series: [
              {
                name: '短信类型',
                type: 'pie',
                radius: ['50%', '70%'],
                avoidLabelOverlap: false,
                label: {
                  show: false,
                  position: 'center'
                },
                emphasis: {
                  label: {
                    show: true,
                    fontSize: '16',
                    fontWeight: 'bold'
                  }
                },
                labelLine: {
                  show: false
                },
                data: safeDistribution
              }
            ]
          });
          charts.status = typeChart;
        }

        // 高频手机号图
        if (data.frequent_phones && Array.isArray(data.frequent_phones)) {
          const phoneChart = echarts.init(document.getElementById('phone-chart'));
          phoneChart.setOption({
            tooltip: {
              trigger: 'axis',
              axisPointer: {
                type: 'shadow'
              }
            },
            xAxis: {
              type: 'category',
              data: data.frequent_phones.map(item => item.phone),
              axisLabel: {
                interval: 0,
                rotate: 30
              }
            },
            yAxis: {
              type: 'value'
            },
            series: [
              {
                name: '发送次数',
                type: 'bar',
                data: data.frequent_phones.map(item => item.value)
              }
            ]
          });
          charts.engineer = phoneChart;
        }

        // 趋势图
        if (data.trends && data.trends.dates) {
          const trendChart = echarts.init(document.getElementById('trend-chart'));
          trendChart.setOption({
            tooltip: {
              trigger: 'axis'
            },
            xAxis: {
              type: 'category',
              boundaryGap: false,
              data: data.trends.dates
            },
            yAxis: {
              type: 'value'
            },
            series: [
              {
                name: '发送量',
                type: 'line',
                data: data.trends.counts
              }
            ]
          });
          charts.trend = trendChart;
        }
      });
    };



    // 导出数据
    const exportData = () => {
      ElMessage.info('导出功能开发中...');
    };

    // 处理搜索
    const handleSearch = () => {
      fetchData();
    };

    // 重置筛选条件
    const resetFilters = () => {
      filters.dateRange = getDefaultDateRange();
      filters.engineer_id = '';
      filters.type = 'daily';
      fetchData();
    };

    // 监听窗口大小变化，重新调整图表大小
    window.addEventListener('resize', () => {
      for (const key in charts) {
        if (charts[key]) {
          charts[key].resize();
        }
      }
    });

    // 页面加载时获取数据
    onMounted(() => {
      console.log('短信统计组件加载');
      console.log('BASE_URL:', window.BASE_URL);

      fetchData().then(() => {
        console.log('数据获取完成');
      }).catch(err => {
        console.error('数据获取失败:', err);
      });

      // 检查echarts是否加载
      console.log('echarts:', echarts);

      // 添加调试信息，检查组件是否正确渲染
      console.log('短信统计组件渲染完成');
    });

    return {
      loading,
      dateRangeShortcuts,
      filters,
      overview,
      tableData,
      formatCurrency,
      fetchData,
      exportData,
      handleSearch,
      resetFilters
    };
  }
};
</script>

<style scoped>
.installation-statistics-page {
  padding: 20px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.filter-container {
  margin-bottom: 20px;
}

.stat-cards {
  margin-bottom: 20px;
}

.stat-card {
  height: 120px;
}

.stat-card-content {
  display: flex;
  align-items: center;
  height: 100%;
}

.stat-icon {
  font-size: 48px;
  margin-right: 20px;
  color: #409EFF;
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-title {
  font-size: 16px;
  color: #909399;
  margin-bottom: 10px;
}

.stat-value {
  font-size: 24px;
  font-weight: bold;
  color: #303133;
}

.chart-container {
  margin-top: 20px;
}

.chart-card {
  margin-bottom: 20px;
}

.chart {
  height: 300px;
}

.chart-header, .table-header {
  font-size: 16px;
  font-weight: bold;
}
</style>
