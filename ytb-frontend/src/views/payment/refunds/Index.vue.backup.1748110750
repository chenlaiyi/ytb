<template>
  <div class="page-container">
    <el-card class="page-card">
      <div class="page-header">
        <h2>退款管理</h2>
        <p class="page-description">查看和处理系统中的退款申请</p>
      </div>
      
      <div class="filter-container">
        <el-form :inline="true" :model="listQuery" class="form-inline">
          <el-form-item label="搜索">
            <el-input
              v-model="listQuery.keyword"
              placeholder="订单号/退款单号"
              clearable
              @keyup.enter.native="handleFilter"
            />
          </el-form-item>
          
          <el-form-item label="状态">
            <el-select v-model="listQuery.status" placeholder="全部" clearable>
              <el-option
                v-for="item in statusOptions"
                :key="item.value"
                :label="item.label"
                :value="item.value"
              />
            </el-select>
          </el-form-item>
          
          <el-form-item label="申请时间">
            <el-date-picker
              v-model="dateRange"
              type="daterange"
              align="right"
              unlink-panels
              range-separator="至"
              start-placeholder="开始日期"
              end-placeholder="结束日期"
              value-format="yyyy-MM-dd"
              @change="handleDateRangeChange"
            />
          </el-form-item>
          
          <el-form-item>
            <el-button type="primary" icon="el-icon-search" @click="handleFilter">搜索</el-button>
            <el-button icon="el-icon-refresh" @click="resetFilter">重置</el-button>
          </el-form-item>
        </el-form>
      </div>
      
      <div class="table-container">
        <el-table
          v-loading="listLoading"
          :data="list"
          border
          fit
          highlight-current-row
          style="width: 100%"
        >
          <el-table-column prop="refund_no" label="退款单号" min-width="180" />
          <el-table-column prop="order_no" label="订单号" min-width="180" />
          <el-table-column prop="refund_amount" label="申请退款金额" width="120">
            <template slot-scope="{row}">
              <span>¥{{ row.refund_amount }}</span>
            </template>
          </el-table-column>
          <el-table-column prop="real_refund_money" label="实际退款金额" width="120">
            <template slot-scope="{row}">
              <span>¥{{ row.real_refund_money || 0 }}</span>
            </template>
          </el-table-column>
          <el-table-column prop="user_name" label="申请用户" width="150" />
          <el-table-column prop="status_text" label="状态" width="100">
            <template slot-scope="{row}">
              <el-tag v-if="row.verify_status === 0" type="info">待审核</el-tag>
              <el-tag v-else-if="row.verify_status === 1" type="success">已通过</el-tag>
              <el-tag v-else-if="row.verify_status === 2" type="danger">已拒绝</el-tag>
              <el-tag v-else-if="row.verify_status === 3" type="warning">退款中</el-tag>
              <el-tag v-else-if="row.verify_status === 4" type="success">已退款</el-tag>
              <el-tag v-else>{{ row.status_text }}</el-tag>
            </template>
          </el-table-column>
          <el-table-column prop="created_at" label="申请时间" width="180" />
          <el-table-column label="操作" width="200" fixed="right">
            <template slot-scope="{row}">
              <el-button type="text" size="mini" @click="handleDetail(row)">查看</el-button>
              <el-button
                v-if="row.verify_status === 0"
                type="text"
                size="mini"
                @click="handleAudit(row, 'approve')"
              >通过</el-button>
              <el-button
                v-if="row.verify_status === 0"
                type="text"
                size="mini"
                @click="handleAudit(row, 'reject')"
              >拒绝</el-button>
              <el-button
                v-if="row.verify_status === 3"
                type="text"
                size="mini"
                @click="handleRefund(row)"
              >退款</el-button>
            </template>
          </el-table-column>
        </el-table>
        
        <div class="pagination-container">
          <el-pagination
            background
            @size-change="handleSizeChange"
            @current-change="handleCurrentChange"
            :current-page.sync="listQuery.page"
            :page-sizes="[10, 20, 30, 50]"
            :page-size="listQuery.limit"
            layout="total, sizes, prev, pager, next, jumper"
            :total="total"
          />
        </div>
      </div>
      
      <!-- 退款审核对话框 -->
      <el-dialog
        title="退款审核"
        :visible.sync="auditDialogVisible"
        width="500px"
      >
        <el-form :model="auditForm" ref="auditForm" label-width="100px">
          <el-form-item label="操作">
            <el-tag v-if="auditForm.action === 'approve'" type="success">通过</el-tag>
            <el-tag v-else-if="auditForm.action === 'reject'" type="danger">拒绝</el-tag>
          </el-form-item>
          <el-form-item label="备注">
            <el-input
              type="textarea"
              :rows="4"
              v-model="auditForm.remark"
              placeholder="请输入审核备注"
            />
          </el-form-item>
        </el-form>
        
        <span slot="footer" class="dialog-footer">
          <el-button @click="auditDialogVisible = false">取消</el-button>
          <el-button type="primary" @click="submitAudit" :loading="formLoading">确认</el-button>
        </span>
      </el-dialog>
      
      <!-- 退款处理对话框 -->
      <el-dialog
        title="处理退款"
        :visible.sync="refundDialogVisible"
        width="500px"
      >
        <el-form :model="refundForm" ref="refundForm" label-width="120px" :rules="refundRules">
          <el-form-item label="退款金额" prop="real_refund_money">
            <el-input-number
              v-model="refundForm.real_refund_money"
              :min="0"
              :precision="2"
              :step="0.01"
              controls-position="right"
            />
          </el-form-item>
          <el-form-item label="交易号" prop="transaction_id">
            <el-input
              v-model="refundForm.transaction_id"
              placeholder="退款交易号（选填）"
            />
          </el-form-item>
          <el-form-item label="备注" prop="remark">
            <el-input
              type="textarea"
              :rows="3"
              v-model="refundForm.remark"
              placeholder="退款备注"
            />
          </el-form-item>
        </el-form>
        
        <span slot="footer" class="dialog-footer">
          <el-button @click="refundDialogVisible = false">取消</el-button>
          <el-button type="primary" @click="submitRefund" :loading="formLoading">确认退款</el-button>
        </span>
      </el-dialog>
      
      <!-- 统计概览 -->
      <el-card class="box-card statistics-card" v-if="statsVisible">
        <div slot="header" class="card-header">
          <span>退款概览</span>
          <el-button
            style="float: right; padding: 3px 0"
            type="text"
            icon="el-icon-refresh"
            @click="getStatistics"
          >刷新</el-button>
        </div>
        <div class="stats-container" v-loading="statsLoading">
          <div class="stats-item">
            <div class="stats-label">总退款金额</div>
            <div class="stats-value">¥{{ stats.total_amount || 0 }}</div>
          </div>
          <div class="stats-item">
            <div class="stats-label">总退款笔数</div>
            <div class="stats-value">{{ stats.total_count || 0 }}</div>
          </div>
        </div>
      </el-card>
    </el-card>
  </div>
</template>

<script>
export default {
  name: 'PaymentRefunds',
  data() {
    return {
      list: [],
      total: 0,
      listLoading: true,
      listQuery: {
        page: 1,
        limit: 20,
        keyword: '',
        status: null,
        start_date: '',
        end_date: ''
      },
      dateRange: [],
      statusOptions: [
        { label: '待审核', value: 0 },
        { label: '已通过', value: 1 },
        { label: '已拒绝', value: 2 },
        { label: '退款中', value: 3 },
        { label: '已退款', value: 4 }
      ],
      // 审核相关
      auditDialogVisible: false,
      auditForm: {
        id: null,
        action: '',
        remark: ''
      },
      // 退款相关
      refundDialogVisible: false,
      refundForm: {
        id: null,
        real_refund_money: 0,
        transaction_id: '',
        remark: ''
      },
      refundRules: {
        real_refund_money: [
          { required: true, message: '请输入退款金额', trigger: 'blur' },
          { type: 'number', min: 0.01, message: '金额必须大于0', trigger: 'blur' }
        ]
      },
      formLoading: false,
      // 统计相关
      statsVisible: true,
      statsLoading: false,
      stats: {
        total_amount: 0,
        total_count: 0
      }
    }
  },
  created() {
    this.getList()
    this.getStatistics()
  },
  methods: {
    getList() {
      this.listLoading = true
      this.$http.get('/api/payment/refunds', { params: this.listQuery })
        .then(response => {
          if (response.data.code === 0) {
            this.list = response.data.data
            this.total = response.data.total
          } else {
            this.$message.error(response.data.message || '获取退款记录失败')
          }
          this.listLoading = false
        })
        .catch(error => {
          console.error('获取退款记录失败', error)
          this.$message.error('获取退款记录失败')
          this.listLoading = false
        })
    },
    getStatistics() {
      this.statsLoading = true
      this.$http.get('/api/payment/refunds/statistics', {
        params: {
          start_date: this.listQuery.start_date,
          end_date: this.listQuery.end_date
        }
      })
        .then(response => {
          if (response.data.code === 0) {
            const data = response.data.data || {}
            this.stats = data.overview || {
              total_amount: 0,
              total_count: 0
            }
          } else {
            this.$message.error(response.data.message || '获取统计数据失败')
          }
          this.statsLoading = false
        })
        .catch(error => {
          console.error('获取统计数据失败', error)
          this.$message.error('获取统计数据失败')
          this.statsLoading = false
        })
    },
    handleFilter() {
      this.listQuery.page = 1
      this.getList()
      this.getStatistics()
    },
    resetFilter() {
      this.listQuery = {
        page: 1,
        limit: 20,
        keyword: '',
        status: null,
        start_date: '',
        end_date: ''
      }
      this.dateRange = []
      this.getList()
      this.getStatistics()
    },
    handleSizeChange(val) {
      this.listQuery.limit = val
      this.getList()
    },
    handleCurrentChange(val) {
      this.listQuery.page = val
      this.getList()
    },
    handleDateRangeChange(dates) {
      if (dates) {
        this.listQuery.start_date = dates[0]
        this.listQuery.end_date = dates[1]
      } else {
        this.listQuery.start_date = ''
        this.listQuery.end_date = ''
      }
    },
    handleDetail(row) {
      // 这里可以实现查看详情页面
      this.$message.info('查看退款详情:' + row.id)
    },
    handleAudit(row, action) {
      this.auditForm = {
        id: row.id,
        action: action,
        remark: ''
      }
      this.auditDialogVisible = true
    },
    submitAudit() {
      this.formLoading = true
      this.$http.post(`/api/payment/refunds/${this.auditForm.id}/audit`, this.auditForm)
        .then(response => {
          if (response.data.code === 0) {
            this.$message.success(this.auditForm.action === 'approve' ? '退款申请已通过' : '退款申请已拒绝')
            this.auditDialogVisible = false
            this.getList()
          } else {
            this.$message.error(response.data.message || '审核操作失败')
          }
          this.formLoading = false
        })
        .catch(error => {
          console.error('审核操作失败', error)
          this.$message.error('审核操作失败')
          this.formLoading = false
        })
    },
    handleRefund(row) {
      this.refundForm = {
        id: row.id,
        real_refund_money: row.refund_amount,
        transaction_id: '',
        remark: ''
      }
      this.refundDialogVisible = true
    },
    submitRefund() {
      this.$refs.refundForm.validate(valid => {
        if (valid) {
          this.formLoading = true
          this.$http.post(`/api/payment/refunds/${this.refundForm.id}/refund`, this.refundForm)
            .then(response => {
              if (response.data.code === 0) {
                this.$message.success('退款处理成功')
                this.refundDialogVisible = false
                this.getList()
                this.getStatistics()
              } else {
                this.$message.error(response.data.message || '退款处理失败')
              }
              this.formLoading = false
            })
            .catch(error => {
              console.error('退款处理失败', error)
              this.$message.error('退款处理失败')
              this.formLoading = false
            })
        }
      })
    },
    goBack() {
      this.$router.go(-1)
    }
  }
}
</script>

<style scoped>
.page-container {
  padding: 20px;
}
.page-card {
  margin-bottom: 20px;
}
.page-header {
  margin-bottom: 20px;
}
.page-description {
  color: #666;
  margin: 10px 0;
}
.filter-container {
  margin-bottom: 20px;
}
.pagination-container {
  margin-top: 20px;
  text-align: right;
}
.statistics-card {
  margin-top: 20px;
}
.stats-container {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}
.stats-item {
  text-align: center;
  padding: 10px 20px;
}
.stats-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 5px;
}
.stats-value {
  font-size: 24px;
  font-weight: bold;
  color: #409EFF;
}
</style> 