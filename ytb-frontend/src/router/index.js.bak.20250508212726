import { createRouter, createWebHashHistory } from 'vue-router';
import routes from '@/routes';
import { getToken, isTokenExpiringSoon, refreshToken, verifyToken } from '@/utils/auth';
import { ElMessage } from 'element-plus';
import NProgress from 'nprogress';
import 'nprogress/nprogress.css';

// 配置NProgress
NProgress.configure({ 
  showSpinner: false,
  minimum: 0.1,
  easing: 'ease',
  speed: 500
});

const router = createRouter({
  history: createWebHashHistory(),
  routes,
  scrollBehavior() {
    return { top: 0 };
  }
});

// 全局前置守卫
router.beforeEach(async (to, from, next) => {
  // 开始进度条
  NProgress.start();
  
  // 获取token
  const token = getToken();
  
  // 如果是登录页面，直接放行
  if (to.path === '/login') {
    if (token) {
      // 如果已登录，重定向到首页
      next({ path: '/' });
    } else {
      // 未登录，允许访问登录页
      next();
    }
    NProgress.done();
    return;
  }
  
  // 如果没有token，重定向到登录页
  if (!token) {
    console.log('未登录，重定向到登录页');
    ElMessage.warning('请先登录');
    next({ path: '/login', query: { redirect: to.fullPath } });
    NProgress.done();
    return;
  }
  
  try {
    // 验证token是否有效
    const isValid = await verifyToken();
    
    if (!isValid) {
      console.log('令牌无效，重定向到登录页');
      ElMessage.error('登录已过期，请重新登录');
      next({ path: '/login', query: { redirect: to.fullPath } });
      NProgress.done();
      return;
    }
    
    // 检查token是否即将过期，如果是则刷新
    if (isTokenExpiringSoon()) {
      console.log('令牌即将过期，尝试刷新');
      const refreshed = await refreshToken();
      if (!refreshed) {
        console.warn('令牌刷新失败');
      }
    }
    
    // 放行
    next();
  } catch (error) {
    console.error('路由守卫错误', error);
    ElMessage.error('系统错误，请重新登录');
    next({ path: '/login', query: { redirect: to.fullPath } });
  }
});

// 全局后置钩子
router.afterEach(() => {
  // 结束进度条
  NProgress.done();
});

export default router;
